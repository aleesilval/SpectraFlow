# Normalize text files
* text=auto
# Force LF for source files
*.c text eol=lf
*.h text eol=lf
*.cpp text eol=lf
# Git LFS tracked types (images, binaries, firmware)
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text
*.elf filter=lfs diff=lfs merge=lfs -text
*.hex filter=lfs diff=lfs merge=lfs -text
*.img filter=lfs diff=lfs merge=lfs -text
# Track static docs/images under esp-claw docs
firmware/lib/esp-claw/docs/static/** filter=lfs diff=lfs merge=lfs -text
